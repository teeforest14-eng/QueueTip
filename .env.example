# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/queuetip?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# App URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Optional: set to "true" to simulate premium for local testing
# QUEUETIP_FORCE_PREMIUM="false"

# Case status sync: "mock" (default) or "live" (USCIS Torch Case Status API, server-side only)
# https://developer.uscis.gov/api/case-status
# USCIS_CASE_STATUS_MODE="mock"

# --- USCIS Torch (only when USCIS_CASE_STATUS_MODE=live) ---
# From your Developer Team App on developer.uscis.gov — never commit real values.
# USCIS_CLIENT_ID=""
# USCIS_CLIENT_SECRET=""
# Optional overrides (defaults = USCIS integration sandbox):
# USCIS_OAUTH_TOKEN_URL="https://api-int.uscis.gov/oauth/accesstoken"
# USCIS_CASE_STATUS_API_BASE="https://api-int.uscis.gov"
# Production URLs are provided by USCIS after you pass their demo / go-live process.
